# LiveKit Configuration
API_KEY=your_livekit_api_key
API_SECRET=your_livekit_api_secret
API_URL=wss://your-project.livekit.cloud

# Database
DB_PASSWORD=your_mysql_password

# Gemini AI (Get from: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Whisper Command (Local Windows Development)
WHISPER_COMMAND="D:/Java_Full_Stack/video conferencing/AI/.venv/Scripts/python.exe" "D:/Java_Full_Stack/video conferencing/AI/transcribe.py" --input "%s" --model base --device cpu --compute_type int8

# For Linux/Production (Render, AWS, etc.), use:
# WHISPER_COMMAND=python3 AI/transcribe.py --input "%s" --model base --device cpu --compute_type int8
